        <mxCell id="se-footer" value="FK: subscription_id → subscriptions(id)&#xa;Used for Outbox Pattern (event publishing)" style="text;strokeColor=none;fillColor=#EEEEEE;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=10;fontStyle=2;fontColor=#424242;" vertex="1" parent="subscription-events-table">
          <mxGeometry y="204" width="380" height="56" as="geometry" />
