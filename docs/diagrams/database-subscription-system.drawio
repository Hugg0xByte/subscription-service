          <mxGeometry y="30" width="820" height="8" as="geometry" />
        </mxCell>
        <mxCell id="constraint-1" value="PARTIAL UNIQUE INDEX  uq_active_subscription_per_user  ON subscriptions(user_id)  WHERE status IN ('ATIVA', 'PENDENTE_PAGAMENTO')" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=11;fontColor=#1B5E20;fontStyle=1;" vertex="1" parent="constraints-group">
          <mxGeometry y="38" width="820" height="30" as="geometry" />
        </mxCell>
        <mxCell id="constraint-1-desc" value="    → Garante apenas uma assinatura ativa por usuário (status ATIVA ou PENDENTE_PAGAMENTO)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=10;fontColor=#666666;" vertex="1" parent="constraints-group">
          <mxGeometry y="68" width="820" height="24" as="geometry" />
        </mxCell>
        <mxCell id="constraint-2" value="PERFORMANCE INDEX  idx_subscriptions_due_renewal  ON subscriptions(status, expiration_date)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=11;fontColor=#1B5E20;fontStyle=1;" vertex="1" parent="constraints-group">
          <mxGeometry y="92" width="820" height="30" as="geometry" />
        </mxCell>
        <mxCell id="constraint-2-desc" value="    → Otimiza queries de renovação automática (batch renewal scheduler)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=10;fontColor=#666666;" vertex="1" parent="constraints-group">
          <mxGeometry y="122" width="820" height="24" as="geometry" />
        </mxCell>
        <mxCell id="constraint-3" value="UNIQUE CONSTRAINT  payment_attempts.idempotency_key" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=11;fontColor=#1B5E20;fontStyle=1;" vertex="1" parent="constraints-group">
          <mxGeometry y="146" width="820" height="30" as="geometry" />
        </mxCell>
        <mxCell id="constraint-3-desc" value="    → Previne cobranças duplicadas por ciclo de faturamento (idempotency)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=10;fontColor=#666666;" vertex="1" parent="constraints-group">
          <mxGeometry y="176" width="820" height="24" as="geometry" />
