        <mxCell id="rel-pm-users" value="N:1&#xa;user_id → users.id" style="endArrow=ERmandOne;startArrow=ERmany;html=1;rounded=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#1565C0;fontSize=10;fontColor=#1565C0;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="payment-methods-table" target="users-table">
