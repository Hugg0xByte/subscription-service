        <mxCell id="rel-se-subs" value="N:1&#xa;subscription_id → subscriptions.id" style="endArrow=ERmandOne;startArrow=ERmany;html=1;rounded=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#1565C0;fontSize=10;fontColor=#1565C0;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="se-col-2" target="subs-col-10">
